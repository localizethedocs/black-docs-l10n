"  formatters_by_ft = {\n"
"    python = { \"black\" },\n"
"  },\n"
"})\n"
msgstr ""

#: ../../../integrations/editors.md:377
msgid "To format on save, add:"
msgstr ""

#: ../../../integrations/editors.md:379
msgid ""
"require(\"conform\").setup({\n"
"  formatters_by_ft = {\n"
"    python = { \"black\" },\n"
"  },\n"
"  format_on_save = {\n"
"    timeout_ms = 500,\n"
"    lsp_format = \"fallback\",\n"
"  },\n"
"})\n"
