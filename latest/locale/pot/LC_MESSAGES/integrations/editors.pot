#: ../../../integrations/editors.md:397
msgid "Simple command"
msgstr ""

#: ../../../integrations/editors.md:399
msgid ""
"You can invoke _Black_ on the current file directly from Neovim without any "
"plugins:"
msgstr ""

#: ../../../integrations/editors.md:401
msgid ":!black %\n"
msgstr ""

#: ../../../integrations/editors.md:405
msgid "To create a convenient `:Black` command, add this to your `init.lua`:"
msgstr ""

#: ../../../integrations/editors.md:407
msgid ""
"vim.api.nvim_create_user_command(\n"
"  \"Black\",\n"
"  function()\n"
"    vim.cmd(\"!black \" .. vim.fn.expand(\"%\"))\n"
"  end,\n"
"  { nargs = 0 }\n"
")\n"
msgstr ""

